# Dotfiles environment — copy to .env (gitignored) and adjust paths for your machine.
# claude/env.sh loads these at the top of every hook/cron script.
# Variables with no default shown are REQUIRED; those marked Optional have a built-in fallback.

# ---------------------------------------------------------------------------
# Core paths (consumed by env.sh and all hooks/crons)
# ---------------------------------------------------------------------------

# Obsidian vault root (iCloud-synced in the default install on macOS)
OBSIDIAN_VAULT="$HOME/Library/Mobile Documents/iCloud~md~obsidian/Documents/YourVault"

# Log directory for all cron/hook output (created automatically on first run)
CLAUDE_LOG_DIR="$HOME/Library/Logs/claude-crons"

# JSON map of org-keyword → vault folder (consumed by claude/hooks/detect-org.sh)
ORG_MAP="$HOME/.claude/org-map.json"

# ---------------------------------------------------------------------------
# Claude CLI binary (consumed by env.sh, healthcheck.sh, daily-retrospective.sh,
# daily-retro-evening.sh, weekly-finalize.sh)
# ---------------------------------------------------------------------------

# Optional: force a specific Claude CLI binary path.
# If unset, env.sh walks a resolution chain:
#   ~/.local/bin/claude → ~/.npm-packages/bin/claude → /opt/homebrew/bin/claude
# CLAUDE_BIN="$HOME/.local/bin/claude"

# ---------------------------------------------------------------------------
# Cron tuning (consumed by individual cron scripts)
# ---------------------------------------------------------------------------

# Optional: disk-space threshold for mac-cleanup-scan.sh (bytes; default 1 GiB).
# Lower this during testing so the scan fires even on a near-empty machine.
# THRESHOLD_BYTES=1073741824
