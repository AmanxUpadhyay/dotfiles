# =============================================================================
# .env.example — Environment Variable Template
# =============================================================================
# WHY: Documents every environment variable the project needs. Copy to .env
# and fill in values. .env is gitignored; .env.example is committed so
# new developers (and Claude) know what's required.
#
# SETUP: cp .env.example .env && edit .env
# Location: <project-root>/.env.example
# =============================================================================

# --- Application ---
APP_NAME=project-name
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-random-string

# --- Database ---
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/project_db
DATABASE_ECHO=false

# --- Redis (if using caching/background jobs) ---
# REDIS_URL=redis://localhost:6379/0

# --- Authentication ---
# JWT_SECRET_KEY=change-me
# JWT_ALGORITHM=HS256
# JWT_EXPIRATION_MINUTES=30

# --- External APIs ---
# API_KEY_SERVICE_NAME=your-api-key-here

# --- AWS (if applicable) ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=eu-west-2

# --- Azure (if applicable) ---
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
